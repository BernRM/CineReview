# Variáveis usadas no deploy da stack do Swarm.
#
# ATENÇÃO: o `docker stack deploy` NÃO lê arquivos .env automaticamente
# (diferente do `docker compose`). Exporte as variáveis na sessão antes do deploy:
#
#   set -a; . docker-stack/.env; set +a
#   docker stack deploy -c docker-stack/docker-stack.yml cineview
#
# A senha do banco NÃO fica aqui — é um secret do Swarm criado via CLI:
#   printf "minha_senha_forte" | docker secret create db_password -

POSTGRES_DB=cinereview
TMDB_API_TOKEN=
SESSION_SECRET=troque_por_um_valor_longo_e_aleatorio
COOKIE_SECURE=false
ADMIN_EMAIL=admin@exemplo.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque_a_senha_do_admin
DEMO_SEED_ENABLED=true
GRAFANA_ADMIN_PASSWORD=admin
